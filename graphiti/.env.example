# Graphiti stack config (graphiti/docker-compose.yml). Copy to graphiti/.env.

# --- LLM + embeddings (Graphiti's prebuilt server is OpenAI-compatible) ---
# Cloud (recommended to start — best structured-output extraction):
OPENAI_API_KEY=sk-...
# Local / OpenAI-compatible alternative (e.g. Ollama) — set the base URL + model names,
# and use a dummy OPENAI_API_KEY=ollama:
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# MODEL_NAME=llama3.1:8b
# EMBEDDER_MODEL_NAME=nomic-embed-text

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687
# GRAPHITI_PORT=8000

# --- Brain side (set in the brain's env, NOT here) ---
# GRAPHITI_URL=http://localhost:8000   # where the brain reaches the graph service
