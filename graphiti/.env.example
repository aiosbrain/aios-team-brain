# Graphiti stack config (graphiti/docker-compose.yml). Copy to graphiti/.env.
# The `graph` service loads this file via `env_file:`, so any var you OMIT here stays truly unset
# in the container (→ the image reads it as None and uses its OpenAI defaults). Do NOT set an
# optional var to an empty string — e.g. an empty OPENAI_BASE_URL is treated as "set" by the image
# and breaks every LLM call. Leave it commented out unless you actually use a local model.

# --- LLM + embeddings (Graphiti's prebuilt server is OpenAI-compatible) ---
# Cloud (recommended to start — best structured-output extraction):
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4o
# EMBEDDING_MODEL_NAME=text-embedding-3-small   # optional; default is fine (note: var is EMBEDDING_, not EMBEDDER_)
# Local / OpenAI-compatible alternative (e.g. Ollama) — uncomment these and use a dummy key:
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# MODEL_NAME=llama3.1:8b
# EMBEDDING_MODEL_NAME=nomic-embed-text

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687
# GRAPHITI_PORT=8000

# --- Brain side (set in the brain's env, NOT here) ---
# GRAPHITI_URL=http://localhost:8000   # where the brain reaches the graph service
