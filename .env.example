# ── Database backend (configurable; pick ONE) ────────────────────────────────
# DB_BACKEND selects the runtime. Default = "postgres" (the self-host target,
# e.g. Railway). Set "supabase" to opt into the legacy managed backend.
# NEXT_PUBLIC_DB_BACKEND must mirror it so client components branch correctly.
DB_BACKEND=postgres
NEXT_PUBLIC_DB_BACKEND=postgres

# ── Postgres backend (default) ───────────────────────────────────────────────
# Required when DB_BACKEND=postgres. A standard Postgres connection string.
# Load the schema with `npm run pg:schema`. Auth is a signed cookie (no Supabase).
DATABASE_URL=
# PGSSL=require        # set for managed providers that require TLS (e.g. Railway)
AUTH_SECRET=           # secret for signing the auth session cookie (postgres mode)
APP_URL=               # absolute base URL (e.g. https://...railway.app) — required for
                       # invite/magic links built in server actions (no request origin there)
# ── Transactional email (magic links + invites). Preference: Resend → SMTP → dev-log.
RESEND_API_KEY=        # Resend API key (preferred sender)
RESEND_FROM=           # verified-domain from-address, e.g. "AIOS Team Brain <noreply@yourdomain>"
                       # (Resend's onboarding@resend.dev only delivers to the account owner)
SMTP_URL=              # fallback transport if no Resend key, e.g. smtp://user:pass@host:587
SMTP_FROM=             # fallback from-address

# ── Supabase backend (legacy; only when DB_BACKEND=supabase) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM provider: CLOUD (default) ────────────────────────────────────────────
# Leave LLM_BASE_URL unset to answer queries with the Anthropic cloud API.
ANTHROPIC_API_KEY=

# ── LLM provider: LOCAL (optional) ───────────────────────────────────────────
# Set LLM_BASE_URL to stream answers from a local OpenAI-compatible endpoint
# (Ollama, Hermes, llama.cpp, LM Studio) instead of Anthropic. Cost is $0.
# When set, ANTHROPIC_API_KEY is ignored. See docs/PROVIDERS.md.
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1-8b-64k:latest          # any model your endpoint serves
# OPENAI_API_KEY=local                       # placeholder; most local servers ignore it

# ── Retrieval reranker (optional, local or cloud) ────────────────────────────
# Reorders retrieved sources by cross-encoder relevance before the LLM sees
# them. Local default = a llama-server --reranking instance (Qwen3-Reranker).
# Point at a hosted endpoint (Cohere/Voyage/ZeroEntropy wire shape) for cloud.
# Unset = keep Postgres ranking order.
# RERANK_URL=http://localhost:8081/v1/rerank
# RERANK_MODEL=qwen3-reranker-0.6b
# RERANK_TOKEN=                              # bearer token for hosted rerankers
# RERANK_TIMEOUT_MS=4000

# ── External retrieval augmentation (optional, advanced) ─────────────────────
# Merge extra sources from an external retrieval service (e.g. a GBrain adapter
# or a cloud retrieval API). Contract: POST {query,limit,tier} -> {sources:[...]}.
# Unset = Postgres-only retrieval. See docs/PROVIDERS.md.
# RETRIEVAL_AUGMENT_URL=http://localhost:8791/retrieve
# RETRIEVAL_AUGMENT_TOKEN=
# RETRIEVAL_AUGMENT_LIMIT=6
# RETRIEVAL_AUGMENT_TIMEOUT_MS=3000

# ── Plane backlog seed (optional; usually loaded from ../aios-workspace/.env) ─
# PLANE_API_KEY=
# PLANE_WORKSPACE_SLUG=aios-alpha
# PLANE_BASE_URL=https://api.plane.so
# PLANE_PROJECT_ID=
# Default assignee for seeded/updated work items. Prefer email/name in shared
# examples; use PLANE_ASSIGNEE_ID only in private env files.
# PLANE_ASSIGNEE_EMAIL=
# PLANE_ASSIGNEE_NAME=
# PLANE_ASSIGNEE_ID=

# ── Error monitoring: Sentry (optional) ──────────────────────────────────────
# All Sentry config is env-driven and fully inert when unset: with no DSN the
# SDK init is a no-op and sends nothing; with no auth token the build skips
# source-map upload. NEVER commit a real DSN or auth token.
#
# DSNs (identify the project; safe-ish but still treat as config, not source):
#   SENTRY_DSN              — server + edge runtimes (read in sentry.{server,edge}.config.ts)
#   NEXT_PUBLIC_SENTRY_DSN  — browser bundle (read in instrumentation-client.ts).
#                             Inlined into client JS by Next, so it IS public.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
#
# Trace sampling (0 = no performance tracing; 1 = sample everything). Optional.
# SENTRY_TRACES_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
#
# Build-time source-map upload (so stack traces are un-minified in Sentry).
# Only used by `next build` via withSentryConfig. Generate the auth token at
# https://sentry.io/settings/account/api/auth-tokens/ (scope: project:releases).
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=      # SECRET — never commit. CI/build env only.
