# Brain connection (the sidecar talks to the brain over HTTP only).
BRAIN_URL=http://127.0.0.1:3000
AIOS_API_KEY=aios_xxxxxxxx_yyyyyyyyyyyyyyyyyyyyyyyy   # issued in the brain admin UI to a connector member
AIOS_TEAM=demo                                        # team slug or id (X-AIOS-Team)

# Optional: path to a connections.yaml for `sync` and the webhook app.
CONNECTIONS_YAML=./connections.yaml

# Source secrets are referenced from connections.yaml as ${VAR}; export them here.
# GITHUB_TOKEN=ghp_...            # only needed for private repos / higher rate limits
# GITHUB_WEBHOOK_SECRET=...
# SLACK_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# NOTION_TOKEN=secret_...
# CONFLUENCE_API_TOKEN=...
